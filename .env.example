# ───────────────────────────────────────────────
# Runtime
# ───────────────────────────────────────────────
ENVIRONMENT=production          # development | staging | production
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
REQUIRE_MAGIC=true              # enforce libmagic content-sniffing (recommended in prod)

# ───────────────────────────────────────────────
# Storage — S3-compatible object storage
# (configured for Hetzner Object Storage)
# ───────────────────────────────────────────────
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=https://hel1.your-objectstorage.com
S3_REGION=hel1
S3_BUCKET=your-bucket-name      # اسم الـ bucket اللي عملته في Hetzner Console
# S3_PUBLIC_BASE_URL=           # اختياري: لو فيه CDN أو bucket public
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# ───────────────────────────────────────────────
# Task queue (Redis / Celery)
# ───────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
